{
  "name": "@localhost41/create-qvac-app",
  "version": "0.1.0-alpha.1",
  "description": "QVAC developer tooling package: create-qvac-app",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localhost41/create-qvac-app.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "create-qvac-app": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "node dist/cli.js",
    "test": "pnpm build && vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "verify": "pnpm lint && pnpm test && pnpm pack:check",
    "pack:check": "pnpm build && vitest run test/pack.test.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
